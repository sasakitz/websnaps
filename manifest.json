{
  "manifest_version": 3,
  "name": "WebSnaps",
  "version": "1.0.3",
  "description": "スクリーンショットツール - 範囲選択・編集・保存機能付き",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "clipboardWrite",
    "storage",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "capture-selection": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "選択範囲のスクリーンショット"
    },
    "capture-visible": {
      "suggested_key": {
        "default": "Alt+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "表示範囲のスクリーンショット"
    },
    "capture-fullpage": {
      "suggested_key": {
        "default": "Alt+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "ページ全体のスクリーンショット"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WebSnaps",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
